# --- Supabase ---
# Create a project at https://supabase.com and copy these from Project Settings.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- Database (Postgres via Supabase) ---
# Use the Transaction Pooler URL (port 6543) from Supabase → Connect button.
# Note: the pooler host prefix varies by project (aws-0-, aws-1-, etc.)
# — always copy the exact URL from the Supabase dashboard.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"

# --- Anthropic / Claude API ---
# Get a key from https://console.anthropic.com.
ANTHROPIC_API_KEY="sk-ant-YOUR-KEY"

# --- AI service (Python FastAPI) ---
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_SECRET="change-me-to-a-random-string"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OWNER_USER_ID="your-supabase-auth-users-uuid"
