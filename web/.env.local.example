# --- Supabase ---
# Create a project at https://supabase.com and copy these from Project Settings.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- Database (Postgres via Supabase) ---
# DATABASE_URL goes through the connection pooler (port 6543) for runtime use.
# DIRECT_URL hits Postgres directly (port 5432) and is used by Prisma migrations.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Anthropic / Claude API ---
# Get a key from https://console.anthropic.com.
ANTHROPIC_API_KEY="sk-ant-YOUR-KEY"

# --- AI service (Python FastAPI) ---
# Where the web app finds the AI service. Local dev defaults to localhost:8000.
AI_SERVICE_URL="http://localhost:8000"
# Shared secret used for service-to-service auth in addition to the user's JWT.
AI_SERVICE_SECRET="change-me-to-a-random-string"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
